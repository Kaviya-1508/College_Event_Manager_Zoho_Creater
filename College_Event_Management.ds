			{
				name = "Student"
				type = Customer_Portal
				permissions = {Chat:false, Predefined:false, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Browse and register for upcoming campus events \n"
				ModulePermissions
				{
					registrations
					{
						allFieldsVisible= true 
						ReportPermissions
						{
							registrations_Report={"View"}
							registrations_by_department={"View"}
						}
					}
					event_participation_report
					{
						allFieldsVisible= true 
						ReportPermissions
						{
							event_participation_report_by_department={"View"}
							event_participation_report_Report={"View"}
						}
					}
				}
			}
			"Customer"
			{
				name = "Customer"
				type = Customer_Portal
				permissions = {Chat:true, Predefined:true, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "This is the default profile having only add and view permission.\n"
			}
			roles
			{
				"CEO"
				{
					description = "User belonging to this role can access data of all other users."
				}
			}
	}


