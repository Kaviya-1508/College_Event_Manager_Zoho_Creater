					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Registration Created","Registration Pending Approval","Registration Cancelled","Registration Approved","Registration Rejected","Attendance Marked","Registration Completed"}
			}
		}
	}
	reports
	{
		list registrations_Report
		{
			displayName = "All Registrations"
			show all rows from registrations    
			(
				student_name as "Student Name"
				register_number as "Register Number"
				department as "Department"
				year_1 as "Year"
				event as "Event"
				approval_status as "Approval Status"
				created_by as "Created By"
				created_time as "Created Time"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (year_1 == "1st")
				fields = [year_1]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (year_1 == "2nd")
				fields = [year_1]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (year_1 == "4th")
				fields = [year_1]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban registrations_by_department
		{
			displayName = "Departments"
			show all rows from registrations    
			(
				student_name as "Student Name"
				register_number as "Register Number"
				department as "Department"
				year_1 as "Year"
				event as "Event"
				approval_status as "Approval Status"
				created_by as "Created By"
				created_time as "Created Time"
			)
			options
			(
	 			display field = department
	 		)
		}
		list event_participation_report_Report
		{
			displayName = "All Event Participation Reports"
			show all rows from event_participation_report    
			(
				event as "Event"
				student_name as "Student Name"
				register_number as "Register Number"
				department as "Department"
				year_1 as "Year"
				registration_date as "Registration Date"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (year_1 == "1st")
				fields = [year_1]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (year_1 == "2nd")
				fields = [year_1]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (year_1 == "4th")
				fields = [year_1]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban event_participation_report_by_department
		{
			displayName = "Departments"
			show all rows from event_participation_report    
			(
				event as "Event"
				student_name as "Student Name"
				register_number as "Register Number"
				department as "Department"
				year_1 as "Year"
				registration_date as "Registration Date"
			)
			options
			(
	 			display field = department
	 		)
		}
		list events_Report
		{
			displayName = "All Events"
			show all rows from events    
			(
				event_name as "Event Name"
				department as "Department"
				event_type as "Event Type"
				organizer_name as "Organizer Name"
				start_date as "Start Date"
				end_date as "End Date"
				venue as "Venue"
				max_participants as "Maximum Participants"
				status as "Status"
				description as "Description"
				created_by as "Created By"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Closed")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Open")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Upcoming")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban events_by_department
		{
			displayName = "Departments"
			show all rows from events    
			(
				event_name as "Event Name"
				department as "Department"
				event_type as "Event Type"
				organizer_name as "Organizer Name"
				start_date as "Start Date"
				end_date as "End Date"
				venue as "Venue"
				max_participants as "Maximum Participants"
				status as "Status"
				description as "Description"
				created_by as "Created By"
			)
			options
			(
	 			display field = department
	 		)
		}
	}
