		workflow
		{
		form
		{
			Auto_Set_Event_Status as "Auto Set Event Status"
			{
				type =  form
				form = events

				record event = on add or edit

				on user input of start_date
				{
					actions 
					{
						custom deluge script
						(
											// Get the current date
										currentDate = today;
										// Get the start_date from input (events form)
										startDate = input.start_date;
										// Get the end_date from input (events form)
										endDate = input.end_date;
										// Initialize status variable
										input.status = "";
										// Logic to determine status based on date comparisons
										if(startDate > currentDate)
										{
											input.status = "Upcoming";
										}
										else if(startDate == currentDate)
										{
											input.status = "Open";
										}
										else if(endDate < currentDate)
										{
											input.status = "Completed";
										}
										// Update the status field in the events form
										input.status = input.status;
										// Optional: Log the result for debugging
										info "Event status set to: " + input.status;
						)
					}
				}

			}
			Prevent_Duplicate_Registr as "Prevent Duplicate Registration"
			{
				type =  form
				form = event_participation_report

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											// Check for duplicate registration in the event_participation_report form
										duplicate = registrations[register_number == input.register_number && event.ID == input.event.ID];
										if(duplicate.count() > 0)
										{
											alert "You have already registered for this event.";
											cancel submit;
										}
						)
					}
				}

			}
			Auto_Regitration_date as "Auto Regitration date"
			{
				type =  form
				form = event_participation_report

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											// Set registration date to current date and time when form loads
										input.registration_date = zoho.currenttime;
						)
					}
				}

			}
		}

		schedule
		{
			Registration_successful as "Registration successful"
			{
				type =  schedule
				form = event_participation_report
				start = Added_Time
				time zone = "America/Los_Angeles"
				on start
				{
					actions 
					{
						sendmail
						(
							from : "kaviya2410541@ssn.edu.in"
							to : Email
							subject : "Successfully Registered1"
							message : "<div>Hello ${student_name}, <br></div><div><br></div><div>Your registration has been successfully confirmed!<br></div><div><br></div><div>Event Name : ${event}&nbsp;<br></div><div><br></div><div>We look forward to your participation!<br></div><div><br></div><div>Regards,<br></div><div>Event Team<br></div>"
						)
					}
				}
			}
		}


