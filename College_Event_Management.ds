	 			column = 1   
				width = medium
			)
			event
			(
				type = list	
				displayname = "Event"
				values  = events.ID
    			displayformat = [event_name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			approval_status
			(
				type = picklist
				displayname = "Approval Status"
				values = {"Approved","Rejected","Pending"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			created_by
			(
    			type = text
				displayname = "Created By"
	 			row = 1
	 			column = 1   
				width = medium
			)
			created_time
			(
    			type = datetime
				displayname = "Created Time"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
