 application "College Event Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form event_participation_report
		{
			displayname = "Event Participation Report"
			success message = "Event Participation Report Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			event
			(
				type = list	
				displayname = "Event"
				values  = events.ID
    			displayformat = [event_name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			student_name
			(
    			type = text
				displayname = "Student Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			register_number
			(
    			type = text
				displayname = "Register Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Email
			(
    			type = email
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			department
			(
				type = picklist
				displayname = "Department"
				values = {"Civil","CSE","EEE","ECE","Mechanical","MCA","IT","MBA","Other"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			year_1
			(
				type = picklist
				displayname = "Year"
				values = {"1st","3rd","2nd","4th"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			registration_date
			(
    			type = datetime
				displayname = "Registration Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form events
		{
			displayname = "Events"
			success message = "Event Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			event_name
			(
    			type = text
				displayname = "Event Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			department
			(
				type = picklist
				displayname = "Department"
				values = {"Civil","CSE","EEE","ECE","Mechanical","MCA","IT","MBA","Other"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			event_type
			(
				type = picklist
				displayname = "Event Type"
				values = {"Seminar","Technical","Workshop","Cultural","Hackathon","Sports"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			organizer_name
			(
    			type = text
				displayname = "Organizer Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			start_date
			(
    			type = date
				displayname = "Start Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			end_date
			(
    			type = date
				displayname = "End Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			venue
			(
    			type = text
				displayname = "Venue"
	 			row = 1
	 			column = 1   
				width = medium
			)
			max_participants
			(
				type = number
				displayname = "Maximum Participants"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Upcoming","Closed","Completed","Open"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			description
			(
    			type = textarea
				displayname = "Description"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			created_by
			(
    			type = text
				displayname = "Created By"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Event Created","Event Scheduled","Event Draft","Event Cancelled","Event Published","Event Rescheduled","Event Registration Open","Event Registration Closed","Event In Progress","Event Completed","Event Postponed","Event Closed"}
			}
		}
